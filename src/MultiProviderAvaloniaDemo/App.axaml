<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:log="https://codewf.com"
             x:Class="MultiProviderAvaloniaDemo.App"
             RequestedThemeVariant="Default"
             log:LogNotifications.Mode="InApp"
             log:LogNotifications.MinimumLevel="Error"
             log:LogNotifications.MaxVisibleCount="3"
             log:LogNotifications.QueueCapacity="100"
             log:LogNotifications.ApplicationName="Serilog + CodeWF Demo"
             log:LogNotifications.Duration="0:0:10">
  <Application.Styles>
    <FluentTheme />
  </Application.Styles>
</Application>
