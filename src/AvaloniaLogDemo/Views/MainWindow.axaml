<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:log="https://codewf.com"
        x:Class="AvaloniaLogDemo.Views.MainWindow"
        mc:Ignorable="d"
        d:DesignWidth="1100"
        d:DesignHeight="720"
        Width="1100"
        Height="720"
        MinWidth="820"
        MinHeight="560"
        Icon="/Assets/logo.ico"
        Title="CodeWF Log Viewer Demo">

    <Window.Styles>
        <Style Selector="Border.log-panel">
            <Setter Property="BorderBrush" Value="#D9D9D9" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10" />
        </Style>
        <Style Selector="TextBlock.log-title">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0 0 0 8" />
        </Style>
    </Window.Styles>

    <Grid Margin="12" RowDefinitions="Auto,*">
        <StackPanel Orientation="Horizontal" Spacing="8">
            <Button Content="输出全部级别" Click="WriteAllLevels_OnClick" />
            <Button Content="输出友好异常" Click="WriteFriendlyException_OnClick" />
            <Button Content="仅写文件" Click="WriteFileOnly_OnClick" />
            <Button Content="并发写入 500 条" Click="WriteBurst_OnClick" />
            <Button Content="切换自定义通知样式" Click="ToggleNotificationTheme_OnClick" />
        </StackPanel>

        <Grid Grid.Row="1" Margin="0 10" ColumnDefinitions="2*,*">
            <Border Classes="log-panel" Margin="0 0 5 0">
                <Grid RowDefinitions="Auto,*">
                    <TextBlock Classes="log-title" Text="全部日志" />
                    <log:LogView Grid.Row="1"
                                 FontFamily="Consolas"
                                 FontSize="13"
                                 MinimumLevel="Debug"
                                 MaximumLevel="Critical"
                                 MaxDisplayCount="1000" />
                </Grid>
            </Border>

            <Grid Grid.Column="1" Margin="5 0 0 0" RowDefinitions="*,*">
                <Border Classes="log-panel" Margin="0 0 0 5">
                    <Grid RowDefinitions="Auto,*">
                        <TextBlock Classes="log-title" Text="仅 Info" />
                        <log:LogView Grid.Row="1"
                                     FontFamily="Consolas"
                                     FontSize="13"
                                     MinimumLevel="Information"
                                     MaximumLevel="Information" />
                    </Grid>
                </Border>

                <Border Grid.Row="1" Classes="log-panel" Margin="0 5 0 0">
                    <Grid RowDefinitions="Auto,*">
                        <TextBlock Classes="log-title" Text="Warn ～ Error" />
                        <log:LogView Grid.Row="1"
                                     FontFamily="Consolas"
                                     FontSize="13"
                                     MinimumLevel="Warning"
                                     MaximumLevel="Error" />
                    </Grid>
                </Border>
            </Grid>
        </Grid>

    </Grid>
</Window>
